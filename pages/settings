<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><style>:root{--accent:#89b4fa;--border:rgba(255,255,255,.08);--glass:rgba(255,255,255,.04);--text:rgba(255,255,255,.92);--subtext:rgba(255,255,255,.5)}*{margin:0;padding:0;box-sizing:border-box;font-family:'Inter',sans-serif;user-select:none}body{background:#000;color:var(--text);overflow:hidden;height:100vh;width:100vw;display:flex;align-items:center;justify-content:center}#app-root{height:100%;width:100%;display:flex;align-items:center;justify-content:center;position:relative}.ambient-bg{position:fixed;inset:-10px;z-index:1;background-size:cover;background-position:center;filter:brightness(.4) blur(10px);transition:opacity .5s ease}.overlay-dim{position:fixed;inset:0;z-index:2;background:rgba(0,0,0,.2)}.core-pane{position:relative;z-index:10;width:95%;max-width:650px;max-height:95vh;background:var(--glass);backdrop-filter:blur(25px);-webkit-backdrop-filter:blur(25px);border:1px solid var(--border);border-radius:16px;padding:20px;display:flex;flex-direction:column;gap:14px;box-shadow:0 20px 40px rgba(0,0,0,.4);overflow-y:auto}.core-pane::-webkit-scrollbar{width:4px}.core-pane::-webkit-scrollbar-thumb{background:var(--border);border-radius:10px}.nav{display:flex;justify-content:space-between;align-items:center}h2{font-size:11px;font-weight:800;color:var(--accent);letter-spacing:2px;text-transform:uppercase}label{font-size:9px;font-weight:700;color:var(--subtext);display:block;margin-bottom:6px;letter-spacing:.5px;text-transform:uppercase}input[type=text]{width:100%;background:rgba(255,255,255,.05);border:1px solid var(--border);padding:8px;border-radius:6px;color:#fff;font-size:11px;outline:0;transition:.2s}input[type=text]:focus{border-color:var(--accent)}.split-row{display:grid;grid-template-columns:1.2fr .8fr;gap:15px}@media (max-width:600px){.split-row{grid-template-columns:1fr}}.preset-grid{display:grid;grid-template-columns:repeat(4,1fr
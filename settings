<!DOCTYPE html>
<html>
<head>
    <style>
        body { margin: 0; background: transparent; color: #fff; font-family: 'Inter', sans-serif; text-transform: uppercase; overflow-y: auto; height: 100vh; padding: 60px 40px; scrollbar-width: none; }
        .pane { max-width: 500px; margin: 0 auto; background: rgba(10,12,18,0.7); backdrop-filter: blur(40px); border: 1px solid rgba(255,255,255,0.08); border-radius: 32px; padding: 40px; position: relative; }
        .close { position: absolute; top: 25px; right: 25px; cursor: pointer; opacity: 0.5; transition: 0.3s; }
        .close:hover { opacity: 1; transform: rotate(90deg); }
        h2 { font-size: 10px; letter-spacing: 4px; margin-bottom: 40px; opacity: 0.6; font-weight: 900; }
        .group { margin-bottom: 30px; }
        label { display: block; font-size: 8.5px; letter-spacing: 2px; margin-bottom: 15px; opacity: 0.4; font-weight: 900; }
        input[type="text"], input[type="color"] { width: 100%; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); padding: 15px; border-radius: 12px; color: #fff; font-family: inherit; font-size: 10px; outline: none; transition: 0.3s; }
        input[type="text"]:focus { border-color: rgba(255,255,255,0.3); background: rgba(255,255,255,0.06); }
        input[type="range"] { width: 100%; appearance: none; background: rgba(255,255,255,0.05); height: 2px; border-radius: 2px; outline: none; margin: 15px 0; }
        input[type="range"]::-webkit-slider-thumb { appearance: none; width: 12px; height: 12px; background: #fff; border-radius: 50%; cursor: pointer; transition: 0.2s; box-shadow: 0 0 10px rgba(255,255,255,0.3); }
        .toggle-row { display: flex; align-items: center; justify-content: space-between; cursor: pointer; padding: 10px 0; }
        .switch { width: 34px; height: 18px; background: rgba(255,255,255,0.1); border-radius: 20px; position: relative; transition: 0.3s; }
        .switch::after { content: ''; position: absolute; top: 3px; left: 3px; width: 12px; height: 12px; background: #fff; border-radius: 50%; transition: 0.3s; }
        .active .switch { background: #89b4fa; }
        .active .switch::after { left: 19px; }
    </style>
</head>
<body>
    <div class="pane">
        <div class="close" onclick="window.parent.postMessage('close', '*')"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></div>
        <h2>System Configuration</h2>
        
        <div class="group">
            <label>Interface Title</label>
            <input type="text" id="title" placeholder="HRN | CORE">
        </div>

        <div class="group">
            <label>Accent Color</label>
            <input type="color" id="clr" style="height:45px; padding:5px; cursor:pointer;">
        </div>

        <div class="group">
            <label>Particle Intensity (Sync Only)</label>
            <input type="range" id="op" min="0.1" max="1" step="0.05">
        </div>

        <div class="group">
            <label>Particle Count</label>
            <input type="range" id="int" min="0" max="400" step="10">
        </div>

        <div class="group">
            <div class="toggle-row" id="part-row" onclick="toggle('part')">
                <label style="margin:0; cursor:pointer;">Engine Particles</label>
                <div class="switch"></div>
            </div>
        </div>

        <div class="group">
            <label>Wallpaper URL</label>
            <input type="text" id="bg" placeholder="https://image-url.com/img.jpg">
        </div>

        <div class="group">
            <label>Favicon URL</label>
            <input type="text" id="fav" placeholder="https://site.com/icon.png">
        </div>
    </div>

    <script>
        const fields = ['title', 'clr', 'op', 'int', 'bg', 'fav'];
        const defaults = { title: 'HRN | CORE', clr: '#89b4fa', op: 0.8, int: 150, part: true, bg: '', fav: '' };

        function load() {
            fields.forEach(f => {
                const val = localStorage.getItem('hrn_' + f) || defaults[f];
                document.getElementById(f).value = val;
                document.getElementById(f).oninput = () => {
                    localStorage.setItem('hrn_' + f, document.getElementById(f).value);
                    window.parent.postMessage('sync', '*');
                };
            });
            const p = localStorage.getItem('hrn_part') !== 'false';
            if(p) document.getElementById('part-row').classList.add('active');
        }

        function toggle(id) {
            const el = document.getElementById(id + '-row');
            const val = !el.classList.contains('active');
            el.classList.toggle('active');
            localStorage.setItem('hrn_' + id, val);
            window.parent.postMessage('sync', '*');
        }

        load();
    </script>
</body>
</html>

<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><style>:root{--accent:#89b4fa;--border:rgba(255,255,255,.08);--text:rgba(255,255,255,.92)}*{margin:0;padding:0;box-sizing:border-box}body{font-family:'Inter',-apple-system,sans-serif;color:var(--text);overflow:hidden;background:#000}#bg{position:fixed;inset:-10px;background-size:cover;background-position:center;filter:brightness(.35) blur(10px);z-index:0;transform:translateZ(0)}#wrap{position:relative;height:100vh;display:flex;flex-direction:column;padding:25px;z-index:10}#header{flex-shrink:0;margin-bottom:20px}#title-container{display:flex;align-items:center;gap:12px;margin-bottom:15px}#close{cursor:pointer;opacity:.6;display:flex}#close:hover{opacity:1}#close svg{width:22px;height:22px;stroke:currentColor;stroke-width:2.5;fill:none}h1{font-size:20px;letter-spacing:.5px;font-weight:600;opacity:.9}#search{width:100%;background:rgba(255,255,255,.06);border:1px solid var(--border);padding:12px 16px;border-radius:10px;color:#fff;outline:0;font-size:14px}#viewport{flex:1;overflow-y:auto;position:relative;contain:size layout style;scrollbar-width:none;-ms-overflow-style:none}#viewport::-webkit-scrollbar{display:none}#spacer{position:absolute;top:0;left:0;right:0;pointer-events:none}#grid{position:absolute;top:0;left:0;right:0;display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:10px;will-change:transform;transform:translate3d(0,0,0)}.card{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:10px;display:flex;align-items:center;justify-content:center;text-align:center;font-size:11px;font-weight:500;cursor:pointer;height:72px;padding:10px;user-select:none;transition:background .1s}.card:hover{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.15)}</style></head><body><div id="bg"></div><div id="wrap"><div id="header"><div id="title-container"><div id="close" onclick="window.parent.postMessage('close','*')"><svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg></div><h1>Games</h1></div><input id="search" placeholder="Search games..." autocomplete="off"></div><div id="viewport"><div id="spacer"></div><div id="grid"></div></div></div><script>const viewport=document.getElementById('viewport'),grid=document.getElementById('grid'),spacer=document.getElementById('spacer'),search=document.getElementById('search'),bg=document.getElementById('bg');let allGames=[],filteredGames=[];const CARD_HEIGHT=72,GAP=10,OVERSCAN=5;let columns=0,ticking=!1;function openGame(e,t){const a=`/${t}/${e}`,n=window.open("about:blank","_blank");if(!n)return;const o=n.document;o.open(),o.write(`<!DOCTYPE html><html style="margin:0;padding:0;height:100%;overflow:hidden;"><head><meta charset="UTF-8"><style>*{margin:0;padding:0;border:none;outline:none;}body,html{height:100%;width:100%;background:#000;overflow:hidden;}iframe{width:100vw;height:100vh;display:block;border:none;}</style></head><body><iframe src="${a}"></iframe></body></html>`),o.close()}async function applyBackground(){const e=indexedDB.open("hrn_db",1);e.onsuccess=e=>{const t=e.target.result;if(!t.objectStoreNames.contains("background"))return;const a=t.transaction("background","readonly").objectStore("background").get("current_bg");a.onsuccess=()=>{const e=a.result?.value;e&&(bg.style.backgroundImage=`url('${e instanceof Blob?URL.createObjectURL(e):e}')`)}}}function calculateLayout(){const e=viewport.clientWidth;columns=Math.floor((e+GAP)/(155+GAP))||1,spacer.style.height=`${Math.ceil(filteredGames.length/columns)*(72+GAP)}px`}function updateVirtualScroll(){const e=viewport.scrollTop,t=72+GAP;let a=Math.max(0,Math.floor(e/t)-5);const n=Math.ceil(viewport.clientHeight/t)+10,o=a*columns,r=Math.min(filteredGames.length,(a+n)*columns);grid.style.transform=`translate3d(0,${a*t}px,0)`;let s="";for(let e=o;e<r;e++){const t=filteredGames[e];s+=`<div class="card" onclick="openGame('${t.alias}','${t.group}')">${t.name}</div>`}